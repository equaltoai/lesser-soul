{
  "name": "@equaltoai/lesser-soul-site",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build:site": "tsx site/build.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "synth": "npm run build:site && cdk synth -c stage=${STAGE:-lab}",
    "deploy": "npm run build:site && cdk deploy --all",
    "destroy": "cdk destroy --all"
  },
  "dependencies": {
    "@theory-cloud/facetheory": "https://github.com/theory-cloud/FaceTheory/releases/download/v0.1.1/theory-cloud-facetheory-0.1.1.tgz",
    "aws-cdk-lib": "2.243.0",
    "constructs": "10.5.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
